# —— Runtime ——
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Comma-separated origins (browser apps). Required when frontend runs on another origin.
CORS_ORIGIN=http://localhost:3000

# Trust X-Forwarded-* when behind a reverse proxy (nginx, load balancer)
TRUST_PROXY=false

# —— PostgreSQL (Prisma) ——
DATABASE_URL=postgresql://quickpay:quickpay@localhost:5432/quickpay?schema=public

# —— Redis (OTP sessions, BullMQ, optional rate-limit store) ——
REDIS_URL=redis://localhost:6379


# Queue name prefix for BullMQ
QUEUE_PREFIX=quickpay

# —— JWT ——
# Generate strong random strings (e.g. openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# —— Cookies ——
COOKIE_DOMAIN=
# For cross-site cookies in production use none + secure
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# OTP pending session cookie (httpOnly)
OTP_SESSION_COOKIE_NAME=qp_otp_session
# Refresh token (httpOnly)
REFRESH_COOKIE_NAME=qp_refresh

# —— OTP (login / sensitive actions) ——
OTP_TTL_SECONDS=180
OTP_MAX_ATTEMPTS=5
OTP_DELIVERY_CHANNEL=sms
# HMAC secret for OTP codes at rest in Redis (min 32 chars recommended)
OTP_HMAC_SECRET=change-me-otp-hmac-secret-min-32-chars
OTP_EMAIL_FROM=Quick Pay <onboarding@resend.dev>
OTP_EMAIL_SUBJECT=Your Quick Pay verification code
RESEND_API_KEY=
EMAIL_OTP_DISABLED=false

# —— Password hashing ——
BCRYPT_ROUNDS=12
PASSWORD_PEPPER=
# Applied on user creation / password change (min 12, complexity enforced in code)
# Seed uses this for the default admin
SEED_ADMIN_PASSWORD=ChangeMe_StrongP@ssw0rd!

# —— Field encryption (AES-256-GCM, 32-byte key base64) ——
# openssl rand -base64 32
ENCRYPTION_KEY_BASE64=

# —— Beem SMS (https://beem.africa) ——
BEEM_SMS_URL=https://apisms.beem.africa/v1/send
BEEM_USERNAME=your_beem_username
BEEM_PASSWORD=your_beem_password
BEEM_SENDER_ID=INFO
# If true, log OTP to console instead of calling Beem (local dev only)
BEEM_SMS_DISABLED=true

# —— Rate limiting (auth routes) ——
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30

# —— Logging ——
LOG_LEVEL=info

# —— Seed: default admin ——
SEED_ADMIN_EMAIL=admin@solektra.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULL_NAME=System Administrator
SEED_ADMIN_PHONE=250788000000
